[Unit]
Description=Orca near-live ingest service
After=network-online.target docker.service
Wants=network-online.target docker.service

[Service]
Type=simple
User=YOUR_VM_USER
SupplementaryGroups=docker
WorkingDirectory=/home/YOUR_VM_USER/orca_polymarkets
EnvironmentFile=/etc/orca.env
ExecStart=/bin/bash /home/YOUR_VM_USER/orca_polymarkets/scripts/run_ingest_live_vm.sh
Restart=always
RestartSec=15
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
